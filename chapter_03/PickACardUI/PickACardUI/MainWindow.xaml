<Window x:Class="PickACardUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PickACardUI"
        mc:Ignorable="d"
        Title="Card Picker" Height="300" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="43*"/>
            <ColumnDefinition Width="357*"/>
            <ColumnDefinition Width="400*"/>
        </Grid.ColumnDefinitions>

        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20,20,0,0" Grid.ColumnSpan="2">
            <Label FontSize="20" Content="How many cards should I pick?" RenderTransformOrigin="-4.149,-0.058"/>
            <Slider x:Name="numberOfCards" Width="280" Height="25" TickPlacement="BottomRight" IsSnapToTickEnabled="True" Foreground="#FF030303" AutoToolTipPlacement="TopLeft" />
        </StackPanel>

        <Button Grid.Row="1" Content="Pick some cards" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20" Grid.Column="1" Margin="85,0,0,0" Click="Button_Click" />

        <ListBox x:Name="listOfCards" Grid.RowSpan="2" Grid.Column="2" Margin="20,20,20,20" FontSize="20" />
    </Grid>

</Window>
