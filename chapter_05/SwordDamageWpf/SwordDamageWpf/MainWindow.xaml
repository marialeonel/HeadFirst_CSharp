<Window x:Class="SwordDamageWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SwordDamageWpf"
        mc:Ignorable="d"
        Title="SwordDamageWindow" Height="173" Width="300">
    <Grid HorizontalAlignment="Right" Width="300">
        
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <CheckBox 
            x:Name="flaming" 
            Content="Flaming" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Top" 
            Margin="0,22,0,0" 
            Checked="flaming_Checked" 
            FontSize="11" 
            Unchecked="flaming_Unchecked"
        />
        
        <CheckBox 
            x:Name="magic" 
            Grid.Column="1" 
            Content="Magic" 
            HorizontalAlignment="Center" 
            Margin="0,22,0,0" 
            VerticalAlignment="Top" 
            FontSize="11" 
            Checked="magic_Checked" 
            Unchecked="magic_Unchecked"
        />
        
        <Button 
            Content="Roll for damage" 
            HorizontalAlignment="Left" 
            Grid.Row="1" 
            VerticalAlignment="Center" 
            Grid.ColumnSpan="2" 
            Margin="46,0,0,0" 
            Click="Button_Click" 
            Width="209"
        />

        <TextBlock 
            x:Name="damage" 
            HorizontalAlignment="Left" 
            Margin="130,13,0,0" 
            Grid.Row="2" 
            TextWrapping="Wrap" 
            Text="damage" 
            VerticalAlignment="Top" 
            Grid.ColumnSpan="2" 
            FontSize="10"
        />

    </Grid>
</Window>
