<Window x:Class="ExperimentWithControls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExperimentWithControls"
        mc:Ignorable="d"
        Title="Experiments With Controls" Height="450" Width="800">
    <Grid x:Name="Experiments_With_Controls">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label Content="Enter a number" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="18" Margin="10,10,0,0" />
        <TextBlock x:Name="number" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="#" VerticalAlignment="Center" FontSize="24"/>
        <TextBox x:Name="numberTextBox" HorizontalAlignment="Left" Margin="16,44,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="120" FontSize="18" TextChanged="numberTextBox_TextChanged" PreviewTextInput="numberTextBox_PreviewTextInput"/>
        <RadioButton Grid.Column="1" Content="1" HorizontalAlignment="Left" Margin="4,44,0,0" VerticalAlignment="Top"/>
        <RadioButton Grid.Column="1" Content="2" HorizontalAlignment="Left" Margin="34,45,0,0" VerticalAlignment="Top"/>
        <RadioButton Grid.Column="1" Content="3" HorizontalAlignment="Left" Margin="64,45,0,0" VerticalAlignment="Top"/>
        <RadioButton Grid.Column="1" Content="4" HorizontalAlignment="Left" Margin="4,64,0,0" VerticalAlignment="Top"/>
        <RadioButton Grid.Column="1" Content="5" HorizontalAlignment="Left" Margin="34,65,0,0" VerticalAlignment="Top"/>
        <RadioButton Grid.Column="1" Content="6" HorizontalAlignment="Left" Margin="64,65,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="myListBox" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="135,173,265,0" Grid.RowSpan="2" SelectionChanged="ListBox_SelectionChanged" Grid.ColumnSpan="2"/>

    </Grid>
</Window>
